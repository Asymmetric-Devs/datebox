# LangGraph Agent Configuration

# Port for the agent server
AGENT_PORT=3001

# Gemini API Configuration (same as backend)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=2048
GEMINI_TOP_P=0.9

# Internal API for tool calls (events/users/groups/dates)
AGENT_API_BASE_URL=http://127.0.0.1:8787
AGENT_API_TIMEOUT_SECONDS=20
# Optional. You can also pass per-request token in context.api_token
AGENT_API_BEARER_TOKEN=

# Agent trace logs (request/tool/response)
AGENT_TRACE_ENABLED=true
AGENT_TRACE_PREVIEW_CHARS=260

# Debug mode
DEBUG=false
